<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Open Session - Your design workflow, upgraded. Figma templates, AI workflows, and the latest designer insights">
    <meta property="og:title" content="Open Session">
    <meta property="og:description" content="Your design workflow, upgraded. Figma templates, AI workflows, and the latest designer insights">
    <meta property="og:image" content="assets/images/3D Logo_rotation_square_compressed.gif">
    <title>Open Session | Links</title>

    <!-- Google Fonts (fallbacks) -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Preload critical local fonts -->
    <link rel="preload" as="font" href="assets/fonts/NeueHassGrotesk_Text/NHaasGroteskTXPro-55Rg.woff2" type="font/woff2" crossorigin>
    <link rel="preload" as="font" href="assets/fonts/NeueHassGrotesk_Display/NeueHaasDisplayBold.woff2" type="font/woff2" crossorigin>
    <link rel="preload" as="font" href="assets/fonts/offbit_Web/OffBit-101Bold.woff2" type="font/woff2" crossorigin>

    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-5DQWPG4P');</script>
    <!-- End Google Tag Manager -->

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            /* BOS Design Tokens */
            --bg-primary: #191919;
            --bg-secondary: #1f1f1f;
            --bg-tertiary: #2a2a2a;
            --fg-primary: #FFFAEE;
            --fg-secondary: #d5d1cb;
            --fg-tertiary: #a8a29b;
            --fg-quaternary: #78726a;
            --color-aperol: #FE5102;

            /* Borders */
            --border-secondary: #2e2e2e;
            --border-primary: #3d3d3d;

            /* Radius */
            --radius-brand: 12px;
            --radius-brand-lg: 16px;

            /* Spacing Scale */
            --space-1: 0.25rem;
            --space-2: 0.5rem;
            --space-3: 0.75rem;
            --space-4: 1rem;
            --space-5: 1.25rem;
            --space-6: 1.5rem;
            --space-8: 2rem;
            --space-10: 2.5rem;
            --space-12: 3rem;
            --space-16: 4rem;
            --space-20: 5rem;
            --space-24: 6rem;

            /* Motion */
            --ease-out: cubic-bezier(0.4, 0, 0.2, 1);
            --duration-micro: 150ms;
            --duration-fast: 200ms;
            --duration-content: 400ms;

            /* Shadows (warm, charcoal-based) */
            --shadow-sm: 0 2px 4px rgba(25, 25, 25, 0.2);
            --shadow-md: 0 4px 12px rgba(25, 25, 25, 0.3);
            --shadow-lg: 0 12px 16px -4px rgba(25, 25, 25, 0.3), 0 4px 6px -2px rgba(25, 25, 25, 0.15);
            --shadow-xl: 0 20px 40px -8px rgba(25, 25, 25, 0.4), 0 8px 16px -4px rgba(25, 25, 25, 0.2);
            --shadow-profile: 0 12px 32px rgba(25, 25, 25, 0.5), 0 4px 12px rgba(25, 25, 25, 0.3);

            /* ASCII */
            --ascii-opacity: 0.10;

            /* Typography */
            --font-display: "Neue Haas Grotesk Display Pro", Inter, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
            --font-body: "Neue Haas Grotesk Text Pro", Inter, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        }

        /* Local font faces */
        @font-face {
            font-family: "Neue Haas Grotesk Display Pro";
            src: url("assets/fonts/NeueHassGrotesk_Display/NeueHaasDisplayLight.woff2") format("woff2");
            font-weight: 300;
            font-style: normal;
            font-display: swap;
        }
        @font-face {
            font-family: "Neue Haas Grotesk Display Pro";
            src: url("assets/fonts/NeueHassGrotesk_Display/NeueHaasDisplayRoman.woff2") format("woff2");
            font-weight: 400;
            font-style: normal;
            font-display: swap;
        }
        @font-face {
            font-family: "Neue Haas Grotesk Display Pro";
            src: url("assets/fonts/NeueHassGrotesk_Display/NeueHaasDisplayMedium.woff2") format("woff2");
            font-weight: 500;
            font-style: normal;
            font-display: swap;
        }
        @font-face {
            font-family: "Neue Haas Grotesk Display Pro";
            src: url("assets/fonts/NeueHassGrotesk_Display/NeueHaasDisplayBold.woff2") format("woff2");
            font-weight: 700;
            font-style: normal;
            font-display: swap;
        }
        @font-face {
            font-family: "Neue Haas Grotesk Text Pro";
            src: url("assets/fonts/NeueHassGrotesk_Text/NHaasGroteskTXPro-55Rg.woff2") format("woff2");
            font-weight: 400;
            font-style: normal;
            font-display: swap;
        }
        @font-face {
            font-family: "Neue Haas Grotesk Text Pro";
            src: url("assets/fonts/NeueHassGrotesk_Text/NHaasGroteskTXPro-65Md.woff2") format("woff2");
            font-weight: 500;
            font-style: normal;
            font-display: swap;
        }
        @font-face {
            font-family: "Neue Haas Grotesk Text Pro";
            src: url("assets/fonts/NeueHassGrotesk_Text/NHaasGroteskTXPro-75Bd.woff2") format("woff2");
            font-weight: 700;
            font-style: normal;
            font-display: swap;
        }

        /* OffBit 101 (Bold) for tagline emphasis */
        @font-face {
            font-family: "OffBit 101";
            src: url("assets/fonts/offbit_Web/OffBit-101Bold.woff2") format("woff2");
            font-weight: 700;
            font-style: normal;
            font-display: swap;
        }

        /* Body — viewport centering */
        body {
            font-family: var(--font-body);
            background-color: var(--bg-primary);
            color: var(--fg-primary);
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        /* ASCII dots animated background */
        #ascii-background {
            position: fixed;
            inset: 0;
            z-index: -2;
            color: var(--fg-primary);
            opacity: var(--ascii-opacity);
            pointer-events: none;
            mix-blend-mode: normal;
            filter: blur(0.3px);
            overflow: hidden;
        }

        .ascii-layer {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
            white-space: pre;
            line-height: 1.2;
            letter-spacing: 0;
            font-size: 10px;
            transition: opacity var(--duration-content) var(--ease-out);
            opacity: 0;
            margin: 0;
            padding: 0;
            overflow: hidden;
            font-variant-ligatures: none;
            font-feature-settings: "liga" 0, "calt" 0;
        }

        .ascii-layer.is-visible {
            opacity: 1;
        }

        /* Toggle support */
        .ascii-dots-disabled #ascii-background { display: none; }

        /* Header gradient */
        .header-gradient {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 260px;
            background: linear-gradient(180deg,
                var(--bg-primary) 0%,
                rgba(25, 25, 25, 0.6) 40%,
                rgba(25, 25, 25, 0) 100%);
            z-index: 0;
            pointer-events: none;
        }

        /* Spacer for header overlap */
        .hero-spacer { height: 30px; }

        /* Container */
        .container {
            max-width: 720px;
            margin: 0 auto;
            padding: 0 var(--space-5);
            position: relative;
            z-index: 2;
            width: 100%;
        }

        /* Profile Section */
        .profile-section {
            text-align: center;
            padding-top: 0;
            margin-bottom: 8px;
        }

        .profile-image {
            width: 64px;
            height: 64px;
            margin: -32px auto var(--space-2);
            border-radius: var(--radius-brand-lg);
            overflow: hidden;
            background: var(--bg-secondary);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            box-shadow: var(--shadow-profile);
            animation: fadeInUp var(--duration-content) var(--ease-out) both;
        }

        .profile-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .profile-name {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: var(--space-1);
            letter-spacing: -0.02em;
            line-height: 1.2;
            font-family: var(--font-display);
            animation: fadeInUp var(--duration-content) var(--ease-out) 100ms both;
        }

        .profile-tagline {
            font-size: 0.875rem;
            color: var(--fg-secondary);
            line-height: 1.5;
            font-weight: 400;
            margin-bottom: 0;
            max-width: 480px;
            margin-left: auto;
            margin-right: auto;
            animation: fadeInUp var(--duration-content) var(--ease-out) 150ms both;
        }

        .profile-tagline strong {
            font-family: "OffBit 101", var(--font-display);
            font-weight: 700;
            display: inline-block;
            font-size: 1rem;
            line-height: 1.3;
            color: var(--fg-primary);
        }

        /* Subscribe Form */
        .subscribe-section {
            margin-bottom: 12px;
            animation: fadeInUp var(--duration-content) var(--ease-out) 200ms both;
        }

        .subscribe-form {
            display: flex;
            gap: 8px;
            max-width: 360px;
            margin: 0 auto;
        }

        .subscribe-input {
            flex: 1;
            min-width: 0;
            height: 40px;
            padding: 0 12px;
            background: var(--bg-secondary);
            border: 1px solid var(--border-secondary);
            border-radius: 8px;
            color: var(--fg-primary);
            font-family: var(--font-body);
            font-size: 0.875rem;
            outline: none;
            transition: border-color var(--duration-micro) var(--ease-out);
        }

        .subscribe-input::placeholder { color: var(--fg-tertiary); }
        .subscribe-input:focus { border-color: var(--border-primary); }

        .subscribe-btn {
            height: 40px;
            padding: 0 16px;
            background: var(--color-aperol);
            color: #fff;
            border: none;
            border-radius: 8px;
            font-family: var(--font-body);
            font-size: 0.875rem;
            font-weight: 600;
            cursor: pointer;
            white-space: nowrap;
            transition: transform var(--duration-micro) var(--ease-out);
        }

        .subscribe-btn:hover { transform: scale(1.02); }
        .subscribe-btn:active { transform: scale(0.97); }
        .subscribe-btn:focus-visible { outline: 2px solid var(--fg-primary); outline-offset: 2px; }

        /* Category Accordions + Icon Buttons */
        .links-section {
            animation: fadeInUp var(--duration-content) var(--ease-out) 250ms both;
        }

        .link-category {
            margin-bottom: 6px;
            border: 1px solid var(--border-secondary);
            border-radius: var(--radius-brand);
            background: var(--bg-secondary);
            overflow: hidden;
            animation: fadeInUp var(--duration-content) var(--ease-out) both;
            transition: box-shadow var(--duration-fast) var(--ease-out),
                        border-color var(--duration-fast) var(--ease-out);
        }

        .link-category:hover {
            box-shadow: 0 2px 8px rgba(25, 25, 25, 0.3);
            border-color: var(--border-primary);
        }

        .category-summary {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 6px 12px;
            font-family: var(--font-body);
            font-size: 0.75rem;
            font-weight: 500;
            color: var(--fg-tertiary);
            text-transform: uppercase;
            letter-spacing: 0.06em;
            cursor: pointer;
            list-style: none;
            user-select: none;
            border-radius: var(--radius-brand);
            transition: background-color var(--duration-micro) var(--ease-out),
                        color var(--duration-micro) var(--ease-out);
        }
        .category-summary::-webkit-details-marker { display: none; }

        .category-summary:hover {
            background: var(--bg-tertiary);
            color: var(--fg-secondary);
        }

        .link-category[open] .category-summary {
            border-bottom: 1px solid var(--border-secondary);
            border-radius: var(--radius-brand) var(--radius-brand) 0 0;
        }

        /* Chevron icon */
        .chevron-icon {
            flex-shrink: 0;
            transition: transform var(--duration-fast) var(--ease-out);
        }

        .link-category[open] .chevron-icon {
            transform: rotate(180deg);
        }

        .category-links {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            padding: 6px 12px;
            overflow: hidden;
            transition: max-height var(--duration-content) var(--ease-out),
                        opacity var(--duration-fast) var(--ease-out),
                        padding var(--duration-fast) var(--ease-out);
        }

        .icon-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 12px;
            background: var(--bg-tertiary);
            border-radius: 8px;
            text-decoration: none;
            color: var(--fg-primary);
            font-family: var(--font-body);
            font-size: 0.8125rem;
            font-weight: 500;
            line-height: 1;
            white-space: nowrap;
            transition: background-color var(--duration-micro) var(--ease-out),
                        transform var(--duration-micro) var(--ease-out),
                        box-shadow var(--duration-micro) var(--ease-out);
            opacity: 0;
            animation: fadeInUp var(--duration-content) var(--ease-out) both;
        }

        .icon-btn img { width: 16px; height: 16px; flex-shrink: 0; }
        .icon-btn:hover {
            background: var(--border-primary);
            transform: translateY(-1px) scale(1.03);
            box-shadow: 0 4px 8px rgba(25, 25, 25, 0.25);
        }
        .icon-btn:active {
            transform: translateY(0) scale(0.97);
            box-shadow: none;
        }
        .icon-btn:focus-visible {
            outline: 2px solid var(--color-aperol);
            outline-offset: 2px;
            z-index: 1;
        }

        /* Footer */
        .footer {
            text-align: center;
            margin-top: var(--space-16);
            padding: var(--space-8) 0 var(--space-12);
            border-top: 1px solid var(--border-secondary);
        }

        .footer-text {
            color: var(--fg-quaternary);
            font-size: 0.875rem;
            line-height: 1.5;
        }

        /* Utility */
        .sr-only {
            position: absolute;
            width: 1px; height: 1px;
            padding: 0; margin: -1px;
            overflow: hidden;
            clip: rect(0, 0, 0, 0);
            white-space: nowrap; border: 0;
        }

        /* Animations */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(12px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Responsive: Tablet (640px+) */
        @media (min-width: 640px) {
            .hero-spacer { height: 50px; }

            .container {
                max-width: 720px;
                padding: 0 var(--space-8);
            }

            .profile-image {
                width: 88px;
                height: 88px;
                margin: -44px auto var(--space-4);
            }

            .profile-name {
                font-size: 2rem;
                margin-bottom: var(--space-2);
            }

            .profile-tagline {
                font-size: 1rem;
                line-height: 1.7;
            }

            .profile-section {
                margin-bottom: 16px;
            }

            .subscribe-section {
                margin-bottom: 16px;
            }

            .subscribe-form { max-width: 400px; }
            .subscribe-input, .subscribe-btn { height: 44px; }

            .link-category { margin-bottom: 8px; }
            .category-summary { padding: 8px 14px; }
            .icon-btn { padding: 10px 14px; font-size: 0.875rem; }
            .icon-btn img { width: 18px; height: 18px; }
            .category-links { gap: 10px; padding: 10px 14px; }
        }

        /* Responsive: Desktop (1024px+) */
        @media (min-width: 1024px) {
            .hero-spacer { height: 70px; }

            .container {
                max-width: 600px;
                padding: 0 var(--space-12);
            }

            .profile-image {
                width: 110px;
                height: 110px;
                margin-top: -55px;
            }

            .profile-name {
                font-size: 2.25rem;
            }

            .profile-section {
                margin-bottom: 24px;
            }

            .subscribe-section {
                margin-bottom: 16px;
            }

            .subscribe-form { max-width: 440px; }

            .category-summary { padding: 10px 16px; }
            .icon-btn { padding: 10px 16px; gap: 8px; }
            .icon-btn img { width: 20px; height: 20px; }
            .link-category { margin-bottom: 10px; }
            .category-links { padding: 10px 16px; }

            .footer {
                margin-top: var(--space-20);
            }
        }

        /* Accessibility: Reduced motion */
        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
            }
        }

        /* Accessibility: High contrast / forced colors */
        @media (forced-colors: active) {
            .link-category {
                border: 1px solid CanvasText;
            }
            .icon-btn:focus-visible {
                outline: 2px solid Highlight;
            }
        }
    </style>
</head>
<body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5DQWPG4P"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <!-- Animated ASCII dots background -->
    <div id="ascii-background" aria-hidden="true">
        <pre class="ascii-layer" id="ascii-a"></pre>
        <pre class="ascii-layer" id="ascii-b"></pre>
    </div>
    <!-- Header Gradient -->
    <div class="header-gradient"></div>

    <!-- Main Container -->
    <main id="main-content" class="container" role="main">
        <div class="hero-spacer" aria-hidden="true"></div>

        <!-- Profile Section -->
        <section class="profile-section" aria-label="Profile">
            <div class="profile-image" aria-hidden="true">
                <img src="assets/images/3D Logo_rotation_square_compressed.gif" alt="Open Session logo">
            </div>
            <h1 class="profile-name">Open Session</h1>
            <p class="profile-tagline"><strong>Your design workflow, upgraded.</strong><br>Figma templates, AI workflows, and the latest designer insights</p>
        </section>

        <!-- Subscribe Form -->
        <section class="subscribe-section" aria-label="Newsletter signup">
            <form class="subscribe-form" action="https://opensession.substack.com/api/v1/free?nojs=true" method="post" target="_blank">
                <label for="subscribe-email" class="sr-only">Email address</label>
                <input type="email" id="subscribe-email" name="email"
                    placeholder="your@email.com" required autocomplete="email"
                    class="subscribe-input">
                <button type="submit" class="subscribe-btn">Subscribe</button>
            </form>
        </section>

        <!-- Categorized Links -->
        <section class="links-section" aria-label="Links">
            <nav aria-label="Categorized links">
                <details class="link-category" open>
                    <summary class="category-summary">
                        <span class="category-label">Design</span>
                        <svg class="chevron-icon" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                            <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </summary>
                    <div class="category-links">
                        <a href="https://open-session.link/figma-social" target="_blank" rel="noopener noreferrer" class="icon-btn">
                            <img src="assets/images/Linkree_figma_thumbnails.svg" alt="" width="16" height="16">
                            <span>Figma</span>
                        </a>
                        <a href="https://open-session.link/website-social" target="_blank" rel="noopener noreferrer" class="icon-btn">
                            <img src="assets/images/Linkree_website_thumbnails.svg" alt="" width="16" height="16">
                            <span>Website</span>
                        </a>
                        <a href="https://github.com/opensesh" target="_blank" rel="noopener noreferrer" class="icon-btn">
                            <img src="assets/images/Linkree_github_thumbnails.svg" alt="" width="16" height="16">
                            <span>GitHub</span>
                        </a>
                    </div>
                </details>
                <details class="link-category" open>
                    <summary class="category-summary">
                        <span class="category-label">Content</span>
                        <svg class="chevron-icon" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                            <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </summary>
                    <div class="category-links">
                        <a href="https://open-session.link/youtube-social" target="_blank" rel="noopener noreferrer" class="icon-btn">
                            <img src="assets/images/Linkree_youtube_thumbnails.svg" alt="" width="16" height="16">
                            <span>YouTube</span>
                        </a>
                        <a href="https://open-session.link/medium-social" target="_blank" rel="noopener noreferrer" class="icon-btn">
                            <img src="assets/images/Linkree_medium_thumbnails.svg" alt="" width="16" height="16">
                            <span>Medium</span>
                        </a>
                        <a href="https://open-session.link/substack-social" target="_blank" rel="noopener noreferrer" class="icon-btn">
                            <img src="assets/images/Linkree_substack_thumbnails.svg" alt="" width="16" height="16">
                            <span>Substack</span>
                        </a>
                    </div>
                </details>
                <details class="link-category" open>
                    <summary class="category-summary">
                        <span class="category-label">Social</span>
                        <svg class="chevron-icon" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                            <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </summary>
                    <div class="category-links">
                        <a href="https://open-session.link/instagram-social" target="_blank" rel="noopener noreferrer" class="icon-btn">
                            <img src="assets/images/Linkree_instagram_thumbnails.svg" alt="" width="16" height="16">
                            <span>Instagram</span>
                        </a>
                        <a href="https://open-session.link/linkedin-social" target="_blank" rel="noopener noreferrer" class="icon-btn">
                            <img src="assets/images/Linkree_linkedin_thumbnails.svg" alt="" width="16" height="16">
                            <span>LinkedIn</span>
                        </a>
                        <a href="https://www.threads.com/@opensession.co?xmt=AQF0glSeDRFHXcN0GohRKyGk4871PQjvCJrwQj0qTdWIheE" target="_blank" rel="noopener noreferrer" class="icon-btn">
                            <img src="assets/images/Linkree_threads_thumbnails.svg" alt="" width="16" height="16">
                            <span>Threads</span>
                        </a>
                    </div>
                </details>
            </nav>
        </section>

        <!-- Footer -->
        <footer class="footer" role="contentinfo">
            <p class="footer-text">&copy; 2025 Open Session</p>
        </footer>
    </main>

    <script>
        // Staggered animation delays for categories
        document.querySelectorAll('.link-category').forEach((el, idx) => {
            el.style.animationDelay = `${250 + idx * 60}ms`;
        });

        // Staggered animation delays for icon buttons within each category
        document.querySelectorAll('.link-category').forEach((category) => {
            category.querySelectorAll('.icon-btn').forEach((btn, btnIdx) => {
                btn.style.animationDelay = `${300 + btnIdx * 80}ms`;
            });
        });

        // Smooth open/close animation for details elements
        document.querySelectorAll('.link-category').forEach((details) => {
            const summary = details.querySelector('.category-summary');
            const content = details.querySelector('.category-links');

            summary.addEventListener('click', (e) => {
                e.preventDefault();
                const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

                if (details.open) {
                    // Closing
                    const height = content.scrollHeight;
                    content.style.maxHeight = height + 'px';
                    content.style.opacity = '1';
                    requestAnimationFrame(() => {
                        content.style.maxHeight = '0px';
                        content.style.opacity = '0';
                        content.style.padding = '0 12px';
                    });
                    const duration = prefersReduced ? 1 : 400;
                    setTimeout(() => {
                        details.removeAttribute('open');
                        content.style.maxHeight = '';
                        content.style.opacity = '';
                        content.style.padding = '';
                    }, duration);
                } else {
                    // Opening
                    details.setAttribute('open', '');
                    const height = content.scrollHeight;
                    content.style.maxHeight = '0px';
                    content.style.opacity = '0';
                    requestAnimationFrame(() => {
                        content.style.maxHeight = height + 'px';
                        content.style.opacity = '1';
                        // Re-trigger staggered entrance for links
                        content.querySelectorAll('.icon-btn').forEach((btn, idx) => {
                            btn.style.animation = 'none';
                            btn.offsetHeight; // force reflow
                            btn.style.animation = '';
                            btn.style.animationDelay = `${idx * 80}ms`;
                        });
                    });
                    const duration = prefersReduced ? 1 : 400;
                    setTimeout(() => {
                        content.style.maxHeight = '';
                        content.style.opacity = '';
                    }, duration);
                }
            });
        });

        // Footer fade-in
        const footer = document.querySelector('.footer');
        if (footer) {
            footer.style.animation = `fadeInUp 400ms cubic-bezier(0.4, 0, 0.2, 1) 550ms both`;
        }

        // ASCII dots background animation
        (function initAsciiDots() {
            const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            if (prefersReduced) return;

            const container = document.getElementById('ascii-background');
            const layerA = document.getElementById('ascii-a');
            const layerB = document.getElementById('ascii-b');
            if (!container || !layerA || !layerB) return;

            let visibleA = true;
            let rafId = 0;
            let timerId = 0;

            function generateFrame(cols, rows, t) {
                const chars = [' ', '.', '·', ':', '•'];
                const output = [];
                const frequency = 0.18;
                for (let y = 0; y < rows; y++) {
                    let line = '';
                    for (let x = 0; x < cols; x++) {
                        const v = (
                            Math.sin((x * frequency) + t) +
                            Math.cos((y * frequency) - t * 0.9) +
                            Math.sin(((x + y) * frequency * 0.7) + t * 0.6)
                        ) / 3;
                        const n = Math.floor(((v + 1) / 2) * (chars.length - 1));
                        line += chars[n];
                    }
                    output.push(line);
                }
                return output.join('\n');
            }

            function measureChar() {
                const ruler = document.createElement('span');
                ruler.textContent = 'M';
                ruler.style.position = 'absolute';
                ruler.style.visibility = 'hidden';
                ruler.style.whiteSpace = 'pre';
                ruler.style.fontFamily = getComputedStyle(layerA).fontFamily;
                ruler.style.fontSize = getComputedStyle(layerA).fontSize;
                ruler.style.lineHeight = getComputedStyle(layerA).lineHeight;
                document.body.appendChild(ruler);
                const rect = ruler.getBoundingClientRect();
                document.body.removeChild(ruler);
                const width = Math.max(1, rect.width);
                const height = Math.max(1, rect.height);
                return { width, height };
            }

            function sizeForViewport() {
                const vw = Math.max(document.documentElement.clientWidth, window.innerWidth || 0);
                const vh = Math.max(document.documentElement.clientHeight, window.innerHeight || 0);
                const { width: charWidth, height: charHeight } = measureChar();
                const cols = Math.max(40, Math.ceil(vw / charWidth));
                const rows = Math.max(22, Math.ceil(vh / charHeight));
                return { cols, rows };
            }

            function render(timeMs) {
                const t = (timeMs || performance.now()) / 900;
                const { cols, rows } = sizeForViewport();
                const next = generateFrame(cols, rows, t);

                const incoming = visibleA ? layerB : layerA;
                const outgoing = visibleA ? layerA : layerB;

                const lines = next.split('\n');
                for (let i = 0; i < lines.length; i++) {
                    if (lines[i].length < cols) {
                        lines[i] = lines[i] + ' '.repeat(cols - lines[i].length);
                    }
                }
                incoming.textContent = lines.join('\n');

                incoming.classList.add('is-visible');
                outgoing.classList.remove('is-visible');
                visibleA = !visibleA;
            }

            function loop() {
                rafId = requestAnimationFrame(() => {
                    render(performance.now());
                });
                timerId = setTimeout(loop, 700);
            }

            render(performance.now());
            loop();

            let resizeTO = 0;
            window.addEventListener('resize', () => {
                clearTimeout(resizeTO);
                resizeTO = setTimeout(() => render(performance.now()), 150);
            });

            const observer = new MutationObserver(() => {
                const disabled = document.body.classList.contains('ascii-dots-disabled');
                if (disabled) {
                    container.style.display = 'none';
                    cancelAnimationFrame(rafId);
                    clearTimeout(timerId);
                } else {
                    container.style.display = '';
                    loop();
                }
            });
            observer.observe(document.body, { attributes: true, attributeFilter: ['class'] });
        })();
    </script>
</body>
</html>
